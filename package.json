{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter ./artifacts/mockup-sandbox dev",
    "dev:api": "pnpm --filter ./artifacts/api-server dev",
    "dev:mobile": "pnpm --filter ./artifacts/coffee-shop dev",

    "dev": "pnpm dev:web",

    "build:web": "pnpm --filter ./artifacts/mockup-sandbox build",
    "build:api": "pnpm --filter ./artifacts/api-server build",
    "build:mobile": "pnpm --filter ./artifacts/coffee-shop build",

    "build": "pnpm run build:api && pnpm run build:web",

    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  },
  "packageManager": "pnpm@9.15.9"
}
